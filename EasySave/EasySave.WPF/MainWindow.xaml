<Window x:Class="EasySave.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasySave.WPF"
        mc:Ignorable="d"
        Title="EasySave" Height="540" Width="980" MinHeight="520" MinWidth="940">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="EasySave" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="{Binding MenuTitleText}" FontSize="12" Opacity="0.75" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding LanguageLabelText}" VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.8"/>
                <ComboBox Width="120"
                          SelectedValue="{Binding SelectedLanguage}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="English" Tag="EN" />
                    <ComboBoxItem Content="Français" Tag="FR" />
                    <ComboBoxItem Content="Español" Tag="ES" />
                    <ComboBoxItem Content="العربية" Tag="AR" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Jobs}"
                     SelectedItem="{Binding SelectedJob}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          VerticalAlignment="Top"
                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          Margin="0,2,0,0"/>

                                <Grid Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding StateText}" FontStyle="Italic" FontSize="12" HorizontalAlignment="Right" />
                                        </DockPanel>

                                        <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                     Height="12"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Margin="0,6,8,0"
                                                     Foreground="LimeGreen"
                                                     Background="#1F1F1F" />

                                        <TextBlock Text="{Binding SourcePath}" TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding TargetPath}" TextWrapping="Wrap" FontSize="12" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" Margin="14,0,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowControls}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <Button Content="{Binding PauseResumeText}"
                                                Command="{Binding PauseResumeCommand}"
                                                Width="84"
                                                Padding="8,3"
                                                Margin="0,0,0,6" />
                                        <Button Content="{Binding CancelText}"
                                                Command="{Binding CancelCommand}"
                                                Width="84"
                                                Padding="8,3" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="2" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding JobEditorTitleText}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="{Binding LabelNameText}" />
                        <TextBox Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <TextBlock Text="{Binding LabelSourceText}" />
                        <DockPanel LastChildFill="True">
                            <Button Content="{Binding BrowseText}" Command="{Binding BrowseSourceCommand}" Width="78" Padding="8,3" Margin="0,0,8,0" DockPanel.Dock="Right" />
                            <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,0,0,10">
                        <TextBlock Text="{Binding LabelTargetText}" />
                        <DockPanel LastChildFill="True">
                            <Button Content="{Binding BrowseText}" Command="{Binding BrowseTargetCommand}" Width="78" Padding="8,3" Margin="0,0,8,0" DockPanel.Dock="Right" />
                            <TextBox Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                    </StackPanel>

                    <CheckBox Grid.Row="4" Content="{Binding DifferentialBackupText}" IsChecked="{Binding IsDifferential}" Margin="0,0,0,14" />

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{Binding CreateText}"
                                Command="{Binding CreateJobCommand}"
                                Width="76"
                                Padding="10,4"
                                Margin="0,0,8,0" />
                        <Button Content="{Binding ModifyText}"
                                Command="{Binding ModifySelectedJobCommand}"
                                Width="76"
                                Padding="10,4"
                                Margin="0,0,8,0" />
                        <Button Content="{Binding DeleteText}"
                                Command="{Binding DeleteSelectedJobCommand}"
                                Width="76"
                                Padding="10,4" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding ExecuteCheckedText}"
                    Command="{Binding ExecuteCheckedJobsCommand}"
                    Width="140"
                    Margin="0,0,8,0"
                    />
            <Button Content="{Binding ExecuteAllText}"
                    Command="{Binding ExecuteAllJobsCommand}"
                    Width="140"
                    Margin="0,0,8,0"
                    />
        </StackPanel>
    </Grid>
</Window>
