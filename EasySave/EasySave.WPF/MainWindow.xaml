<Window x:Class="EasySave.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EasySave.WPF"
        mc:Ignorable="d"
        Title="EasySave" Height="540" Width="980" MinHeight="520" MinWidth="940"
        Background="#F5F7FB">
    <Grid Margin="12">
        <TabControl Background="#FFFFFF" BorderBrush="#B8C3D9">
            <TabItem Header="Create">
                <Border BorderBrush="#B8C3D9" BorderThickness="1" CornerRadius="6" Padding="12" Margin="8" Background="#FFFFFF">
                    <StackPanel>
                        <TextBlock Text="{Binding CreateText}" FontSize="18" FontWeight="SemiBold" Foreground="#2D6CDF" Margin="0,0,0,12" />
                        <TextBlock Text="{Binding JobNameHeaderText}" Foreground="#2A3C5A" FontWeight="SemiBold" />
                        <TextBox Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                        <TextBlock Text="{Binding SourceHeaderText}" Foreground="#2A3C5A" FontWeight="SemiBold" />
                        <DockPanel LastChildFill="True" Margin="0,0,0,10">
                            <Button Content="{Binding BrowseText}" Command="{Binding BrowseSourceCommand}" Width="90" Padding="8,3" Margin="0,0,8,0" DockPanel.Dock="Right" />
                            <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <TextBlock Text="{Binding TargetHeaderText}" Foreground="#2A3C5A" FontWeight="SemiBold" />
                        <DockPanel LastChildFill="True" Margin="0,0,0,10">
                            <Button Content="{Binding BrowseText}" Command="{Binding BrowseTargetCommand}" Width="90" Padding="8,3" Margin="0,0,8,0" DockPanel.Dock="Right" />
                            <TextBox Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>

                        <CheckBox Content="{Binding DifferentialBackupText}" IsChecked="{Binding IsDifferential}" Margin="0,0,0,12" />

                        <Button Content="{Binding CreateText}"
                                Command="{Binding CreateJobCommand}"
                                Width="120"
                                Padding="10,6"
                                HorizontalAlignment="Left"
                                Background="#2D6CDF"
                                Foreground="White"
                                BorderBrush="#2D6CDF" />
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Jobs">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox Grid.Row="0"
                                 ItemsSource="{Binding Jobs}"
                                 SelectedItem="{Binding SelectedJob}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#D2DAE8" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,8" Background="#FFFFFF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      VerticalAlignment="Top"
                                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      Margin="0,2,0,0"/>

                                            <Grid Grid.Column="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <DockPanel LastChildFill="True">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" DockPanel.Dock="Left" />
                                                        <TextBlock Text="{Binding StateText}" FontStyle="Italic" FontSize="12" HorizontalAlignment="Right" />
                                                    </DockPanel>

                                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                                 Height="12"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Margin="0,6,8,0"
                                                                 Foreground="LimeGreen"
                                                                 Background="#1F1F1F" />

                                                    <TextBlock Text="{Binding SourcePath}" TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"/>
                                                    <TextBlock Text="{Binding TargetPath}" TextWrapping="Wrap" FontSize="12" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" Margin="14,0,0,0">
                                                    <Button Content="{Binding DataContext.ModifyText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Command="{Binding DataContext.OpenModifyPanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Width="84"
                                                            Padding="8,3"
                                                            Margin="0,0,0,8"
                                                            Background="#FFF4CC"
                                                            BorderBrush="#F0C75E" />

                                                    <Button Content="{Binding DataContext.DeleteText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            Command="{Binding DataContext.DeleteJobCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Width="84"
                                                            Padding="8,3"
                                                            Margin="0,0,0,12"
                                                            Background="#FFE2E2"
                                                            BorderBrush="#E58A8A" />

                                                    <Button Content="{Binding PauseResumeText}"
                                                            Command="{Binding PauseResumeCommand}"
                                                            Width="84"
                                                            Padding="8,3"
                                                            Margin="0,0,0,6">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowControls}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <Button Content="{Binding CancelText}"
                                                            Command="{Binding CancelCommand}"
                                                            Width="84"
                                                            Padding="8,3">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowControls}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="{Binding ExecuteCheckedText}"
                                    Command="{Binding ExecuteCheckedJobsCommand}"
                                    Width="140"
                                    Margin="0,0,8,0" />
                            <Button Content="{Binding ExecuteAllText}"
                                    Command="{Binding ExecuteAllJobsCommand}"
                                    Width="140" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="2" BorderBrush="#B8C3D9" BorderThickness="1" CornerRadius="6" Padding="12" Background="#FFFFFF">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModifyPanelOpen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                <TextBlock Text="{Binding ModifyText}" FontSize="16" FontWeight="SemiBold" Foreground="#2D6CDF" DockPanel.Dock="Left" />
                                <Button Content="X" Command="{Binding CloseModifyPanelCommand}" Width="28" Height="24" DockPanel.Dock="Right" />
                            </DockPanel>

                            <TextBlock Text="{Binding JobNameHeaderText}" Foreground="#2A3C5A" FontWeight="SemiBold" />
                            <TextBox Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                            <TextBlock Text="{Binding SourceHeaderText}" Foreground="#2A3C5A" FontWeight="SemiBold" />
                            <DockPanel LastChildFill="True" Margin="0,0,0,10">
                                <Button Content="{Binding BrowseText}" Command="{Binding BrowseSourceCommand}" Width="90" Padding="8,3" Margin="0,0,8,0" DockPanel.Dock="Right" />
                                <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <TextBlock Text="{Binding TargetHeaderText}" Foreground="#2A3C5A" FontWeight="SemiBold" />
                            <DockPanel LastChildFill="True" Margin="0,0,0,10">
                                <Button Content="{Binding BrowseText}" Command="{Binding BrowseTargetCommand}" Width="90" Padding="8,3" Margin="0,0,8,0" DockPanel.Dock="Right" />
                                <TextBox Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>

                            <CheckBox Content="{Binding DifferentialBackupText}" IsChecked="{Binding IsDifferential}" Margin="0,0,0,12" />

                            <Button Content="{Binding ModifyText}"
                                    Command="{Binding ModifySelectedJobCommand}"
                                    Width="100"
                                    Padding="8,4"
                                    HorizontalAlignment="Right"
                                    Background="#2D6CDF"
                                    Foreground="White"
                                    BorderBrush="#2D6CDF" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <!-- ScrollViewer indispensable pour éviter que le bas soit coupé sur les petits écrans -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border BorderBrush="#B8C3D9" BorderThickness="1" CornerRadius="6" Padding="15" Margin="10" Background="#FFFFFF">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <!-- 0: Title -->
                                <RowDefinition Height="Auto" />
                                <!-- 1: Language -->
                                <RowDefinition Height="Auto" />
                                <!-- 2: Log Format -->
                                <RowDefinition Height="Auto" />
                                <!-- 3: Log Destination -->
                                <RowDefinition Height="Auto" />
                                <!-- 4: Centralizer URL -->
                                <RowDefinition Height="Auto" />
                                <!-- 5: Encrypted Ext -->
                                <RowDefinition Height="Auto" />
                                <!-- 6: Business Apps -->
                                <RowDefinition Height="Auto" />
                                <!-- 7: Priority Ext -->
                                <RowDefinition Height="Auto" />
                                <!-- 8: Max File Size -->
                                <RowDefinition Height="30" />
                                <!-- 9: Spacer -->
                                <RowDefinition Height="Auto" />
                                <!-- 10: Save Button -->
                            </Grid.RowDefinitions>

                            <!-- Titre -->
                            <TextBlock Grid.Row="0" Text="{Binding SettingsTitleText}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="#2D6CDF" />

                            <!-- Langue -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                <TextBlock Text="{Binding SettingsLanguageText}" Foreground="#2A3C5A" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox SelectedValue="{Binding SelectedLanguage}" SelectedValuePath="Tag" Height="28">
                                    <ComboBoxItem Content="English" Tag="EN" />
                                    <ComboBoxItem Content="Français" Tag="FR" />
                                    <ComboBoxItem Content="Español" Tag="ES" />
                                    <ComboBoxItem Content="العربية" Tag="AR" />
                                </ComboBox>
                            </StackPanel>

                            <!-- Format des Logs -->
                            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                                <TextBlock Text="{Binding SettingsLogFormatText}" Foreground="#2A3C5A" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox SelectedValue="{Binding SelectedLogFormat}" SelectedValuePath="Tag" Height="28">
                                    <ComboBoxItem Content="JSON" Tag="JSON" />
                                    <ComboBoxItem Content="XML" Tag="XML" />
                                </ComboBox>
                            </StackPanel>

                            <!-- Destination des logs -->
                            <StackPanel Grid.Row="3" Margin="0,0,0,12">
                                <TextBlock Text="{Binding SettingsLogDestinationText}" Foreground="#2A3C5A" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox SelectedValue="{Binding SelectedLogDestination}" SelectedValuePath="Tag" Height="28">
                                    <ComboBoxItem Content="Local (PC)" Tag="Local" />
                                    <ComboBoxItem Content="Centralized (Docker)" Tag="Centralized" />
                                    <ComboBoxItem Content="Local + Centralized" Tag="Both" />
                                </ComboBox>
                            </StackPanel>

                            <!-- URL du centraliseur -->
                            <StackPanel Grid.Row="4" Margin="0,0,0,12">
                                <TextBlock Text="{Binding SettingsLogCentralizerUrlText}" Foreground="#2A3C5A" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding LogCentralizerUrl, UpdateSourceTrigger=PropertyChanged}" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                            </StackPanel>

                            <!-- Extensions à chiffrer -->
                            <StackPanel Grid.Row="5" Margin="0,0,0,12">
                                <TextBlock Text="{Binding SettingsExtensionsText}" Foreground="#2A3C5A" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EncryptedExtensionsInput, UpdateSourceTrigger=PropertyChanged}" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                            </StackPanel>

                            <!-- Logiciels Métier -->
                            <StackPanel Grid.Row="6" Margin="0,0,0,12">
                                <TextBlock Text="{Binding SettingsBlockingAppsText}" Foreground="#2A3C5A" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding BusinessSoftwareInput, UpdateSourceTrigger=PropertyChanged}" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                            </StackPanel>

                            <!-- Extensions Prioritaires -->
                            <StackPanel Grid.Row="7" Margin="0,0,0,12">
                                <TextBlock Text="{Binding SettingsPriorityText}" Foreground="#2A3C5A" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding PriorityExtensionsInput, UpdateSourceTrigger=PropertyChanged}" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                            </StackPanel>

                            <!-- Taille Max Fichier (Ko) -->
                            <StackPanel Grid.Row="8" Margin="0,0,0,12">
                                <TextBlock Text="{Binding SettingsMaxFileSizeText}" Foreground="#2A3C5A" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding MaxFileSizeInput, UpdateSourceTrigger=PropertyChanged}" Height="28" VerticalContentAlignment="Center" Padding="5,0"/>
                            </StackPanel>

                            <!-- Bouton Sauvegarder -->
                            <Button Grid.Row="10"
                                Content="{Binding SaveText}"
                                Command="{Binding SaveSettingsCommand}"
                                MinWidth="120"
                                Height="35"
                                FontSize="14"
                                FontWeight="Bold"
                                HorizontalAlignment="Right"
                                Background="#2D6CDF"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand">
                                <!-- Petit effet de style pour le bouton -->
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
